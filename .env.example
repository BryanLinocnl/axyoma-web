# === Proxy de LLM (server-side, NUNCA no app) ===
# Chave real da OpenRouter — só existe aqui, no ambiente da Vercel.
OPENROUTER_KEY=sk-or-...

# Projeto Supabase (mesmo do app).
SUPABASE_URL=https://ygtbhturvumpqgotctmr.supabase.co
# Service-role key (SECRETA) — usada só pelo proxy para debitar via RPC admin.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Verificação de JWT do usuário:
# - Se o projeto usa JWT assimétrico (ES256/RS256), deixe SUPABASE_JWT_SECRET vazio;
#   o proxy verifica pela JWKS pública em ${SUPABASE_URL}/auth/v1/.well-known/jwks.json.
# - Se usa HS256 (legado), cole aqui o "JWT Secret" do projeto (Settings → API).
SUPABASE_JWT_SECRET=

# CORS: ALLOW-LIST de origens separada por vírgula (web app + renderer do desktop).
# Ex.: https://axyoma-ai.app,https://www.axyoma-ai.app,app://axyoma
# "*" (ou vazio) = modo permissivo legado (reflete a origem). Em produção, defina
# a lista real para restringir de fato (Fase 3). O processo main do Electron (Node)
# não envia Origin e não é afetado por CORS.
CORS_ORIGIN=*

# --- Rate limiting / validação do proxy (Fase 3; todos opcionais, têm default) ---
# Chat: 30 req/60s por usuário; corpo <=256KB; max_tokens <=32000.
# CHAT_RATE_LIMIT=30
# CHAT_RATE_WINDOW_S=60
# CHAT_MAX_TOKENS=32000
# CHAT_MAX_BODY_BYTES=262144
# CHAT_MIN_CHARGE_USD=0.0002
# Allow-list de modelos do chat (comma). Se vazio, qualquer modelo bem-formado passa
# (com caps de tokens/tamanho). Setar para travar em um conjunto conhecido.
# CHAT_MODEL_ALLOWLIST=
# Imagens: 10 req/60s por usuário.
# IMAGE_RATE_LIMIT=10
# IMAGE_RATE_WINDOW_S=60
# IMAGE_MIN_CHARGE_USD=0.001
# Refresh de notícias: 6 disparos/hora (global).
# NEWS_REFRESH_LIMIT=6
# NEWS_REFRESH_WINDOW_S=3600

# Painel developer (/conta/dev): e-mails com acesso, separados por vírgula.
ADMIN_EMAILS=blinconl@gmail.com

# === Landing (público — client-side) ===
# Anon key é pública/segura no cliente (Supabase → Settings → API).
NEXT_PUBLIC_SUPABASE_URL=https://ygtbhturvumpqgotctmr.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
